OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...
OPENAI_MODEL=gpt-4o

# Optional: comma-separated ATS board seeds. If omitted, the app uses a small
# default seed list and still falls back to Tavily when it needs more coverage.
# Accepts provider:slug or full ATS URLs.
ATS_BOARD_SOURCES=greenhouse:stripe,lever:postman,ashby:openai

# Optional: tune matching/validation behavior.
JOB_SEARCH_TARGET_RESULTS=50
JOB_LOCATION_KEYWORDS=india,bangalore,bengaluru,hyderabad,pune,mumbai,delhi,gurgaon,gurugram,noida,chennai,remote,apac,asia,global,worldwide,anywhere
